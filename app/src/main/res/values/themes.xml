<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Default/Light Theme -->
    <style name="Theme.Moovie" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Set window background to light to avoid dark flash in light mode -->
        <item name="android:windowBackground">#F5F5F9</item>
        
        <!-- Customize Android 12+ system splash screen -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">#F5F5F9</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_launcher_foreground</item>
    </style>
</resources>