            <gradient
                android:startX="33"
                android:startY="33"
                android:endX="75"
                android:endY="75"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFB300" />
                <item android:offset="1.0" android:color="#FF5722" />
            </gradient>
